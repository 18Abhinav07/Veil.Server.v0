{
  "$schema": "https://schema.railpack.com",
  "provider": "rust",
  "buildAptPackages": [
    "clang",
    "libclang-dev",
    "libsqlite3-dev",
    "pkg-config"
  ],
  "steps": {
    "build": {
      "commands": [
        "...",
        "cargo build -p prover-api -p relayer --release"
      ]
    }
  },
  "deploy": {
    "aptPackages": [
      "libsqlite3-0"
    ],
    "startCommand": "bash scripts/railway-start.sh"
  }
}
